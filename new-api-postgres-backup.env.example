# Copy this file to ./new-api-postgres-backup.env on the server if you want
# backup-specific overrides. R2_ACCOUNT_ID, R2_ACCESS_KEY_ID,
# R2_SECRET_ACCESS_KEY, R2_PUBLIC_BASE_URL, FEISHU_WEBHOOK_URL, and
# FEISHU_KEYWORD are reused from ./new-api-token-export.env by default.

# PostgreSQL container dump settings.
POSTGRES_BACKUP_CONTAINER='postgres-api'
POSTGRES_BACKUP_USER='root'
POSTGRES_BACKUP_DB='new-api'
POSTGRES_BACKUP_OUTPUT_DIR='/backup'
POSTGRES_BACKUP_TIMEOUT_MINUTES='60'

# Use a different bucket from token-exporter while reusing the same R2 keys.
POSTGRES_BACKUP_R2_BUCKET='your-postgres-backup-bucket'
POSTGRES_BACKUP_R2_OBJECT_PREFIX='daily/postgres'

# Remove the local /backup/app-YYYY-MM-DD.dump after successful upload.
POSTGRES_BACKUP_KEEP_LOCAL='false'
